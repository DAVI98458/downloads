-- Fluxiom RM: Advanced Anti-Kick & Stealth Bypass
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 1. Bloqueio por Metatable (__namecall)
-- Captura chamadas de funções como Kick() enviadas pelo jogo
local OldNamecall = nil
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if not checkcaller() then
        -- Bloqueia o método Kick
        if Method == "Kick" or Method == "kick" then
            warn("Fluxiom RM: Tentativa de Kick bloqueada! Motivo: " .. tostring(Args[1] or "Sem motivo"))
            return nil -- Retorna nada, impedindo a execução da função
        end
        
        -- Bloqueia o envio de logs de detecção para o servidor
        if Method == "FireServer" then
            local RemoteName = tostring(Self.Name):lower()
            if RemoteName:find("ban") or RemoteName:find("kick") or RemoteName:find("check") or RemoteName:find("log") then
                print("Fluxiom RM: Remote de Ban/Log bloqueado: " .. Self.Name)
                return nil
            end
        end
    end

    return OldNamecall(Self, ...)
end)

-- 2. Hook Direto na Função Kick (C-Level Hook)
-- Caso o jogo use a função de forma direta, isso garante o bloqueio
local OldKick = nil
OldKick = hookfunction(LocalPlayer.Kick, function(Self, Reason)
    if not checkcaller() then
        warn("Fluxiom RM: Kick direto detectado e bloqueado. Motivo: " .. tostring(Reason))
        return nil
    end
    return OldKick(Self, Reason)
end)

-- 3. Proteção Extra contra Scripts de Banimento de Interface
-- Muitos jogos apenas mostram uma tela de ban e travam seu personagem
task.spawn(function()
    while task.wait(1) do
        if LocalPlayer:FindFirstChild("PlayerGui") then
            for _, v in pairs(LocalPlayer.PlayerGui:GetChildren()) do
                local name = v.Name:lower()
                if name:find("ban") or name:find("kick") or name:find("blacklisted") then
                    v:Destroy()
                    warn("Fluxiom RM: Interface de Ban detectada e removida!")
                end
            end
        end
    end
end)

print("Fluxiom RM: Sistema Anti-Kick/Ban ativado com sucesso.")
