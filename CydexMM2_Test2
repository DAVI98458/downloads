function LoadWindUI()
    local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

    local lp = game.Players.LocalPlayer
    local Circle = Drawing.new("Circle") 
    local Tracers = {}
    _G.InfJump = false
    _G.LockAssassino = false
    _G.TracersVisible = false
    _G.ESPVisible = false
    _G.AntiAFK = true
    _G.HB = false
    _G.KillAuraCircle = false
    _G.FarmCoins = false
    _G.PegarArmaAtivo = false
    _G.CircleRadius = 270

    -- Círculo Vermelho (só borda)
    Circle.Visible = false
    Circle.Radius = _G.CircleRadius
    Circle.Thickness = 1.5
    Circle.Color = Color3.fromRGB(255, 0, 0)
    Circle.Filled = false
    Circle.Transparency = 1

    -- Tracers Brancos
    local function CreateTracer(player)
        if player == lp then return end 
        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = Color3.fromRGB(255, 255, 255)
        line.Thickness = 1.5
        Tracers[player] = line
    end

    local function RemoveTracer(player)
        if Tracers[player] then
            Tracers[player].Visible = false
            Tracers[player]:Remove()
            Tracers[player] = nil
        end
    end

    for _, v in pairs(game.Players:GetPlayers()) do CreateTracer(v) end
    game.Players.PlayerAdded:Connect(CreateTracer)
    game.Players.PlayerRemoving:Connect(RemoveTracer)

    -- Pulo infinito
    game:GetService("UserInputService").JumpRequest:Connect(function()
        if _G.InfJump and lp.Character and lp.Character:FindFirstChildOfClass("Humanoid") then
            lp.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
        end
    end)

    -- [ FARM DE COINS ] --
    spawn(function()
        while wait(0.25) do
            if _G.FarmCoins and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local coinContainer = Workspace:FindFirstChild("Factory") and Workspace.Factory:FindFirstChild("CoinContainer")
                if coinContainer then
                    local closestCoin = nil
                    local closestDist = math.huge
                    local hrpPos = lp.Character.HumanoidRootPart.Position

                    for _, coin in pairs(coinContainer:GetChildren()) do
                        if coin:IsA("BasePart") or coin:IsA("MeshPart") then
                            local dist = (hrpPos - coin.Position).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                closestCoin = coin
                            end
                        end
                    end

                    if closestCoin and closestDist < 1000 then
                        lp.Character.HumanoidRootPart.CFrame = closestCoin.CFrame + Vector3.new(0, 3, 0)
                    end
                end
            end
        end
    end)

    -- [ SISTEMA PEGAR ARMA ] --
    spawn(function()
        while wait(0.5) do
            if _G.PegarArmaAtivo and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local originalPos = lp.Character.HumanoidRootPart.CFrame
                local foundGun = false

                -- Procurar na Workspace por objetos que começam com "Gun" dentro de HumanoidRootPart
                for _, obj in pairs(Workspace:GetDescendants()) do
                    if obj.Name:sub(1, 3) == "Gun" and obj:IsDescendantOf(Workspace) then
                        local hrp = obj:FindFirstAncestorWhichIsA("BasePart")
                        if hrp and hrp.Name == "HumanoidRootPart" then
                            local character = hrp:FindFirstAncestorOfClass("Model")
                            if character then
                                local humanoid = character:FindFirstChildOfClass("Humanoid")
                                if humanoid and humanoid.Health <= 0 then
                                    lp.Character.HumanoidRootPart.CFrame = hrp.CFrame + Vector3.new(0, 2, 0)
                                    foundGun = true
                                    WindUI:Notify({
                                        Title = "🔫 Pegar Arma",
                                        Content = "Arma encontrada! Teleportando...",
                                        Duration = 1
                                    })
                                    wait(0.3)
                                    lp.Character.HumanoidRootPart.CFrame = originalPos
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end)

    -- [ BOTÃO SHOOT MURDER FLUTUANTE ] --
