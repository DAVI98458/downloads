-- [ ANTI-KICK INDETECTÁVEL COM newcclosure ] --
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if Method == "Kick" or Method == "kick" then
        warn("[CYDEX] Tentativa de kick bloqueada!")
        return nil
    end

    return OldNamecall(self, ...)
end))

-- [ ANTI-BAN/DENÚNCIA INDETECTÁVEL COM newcclosure ] --
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if method == "FireServer" or method == "InvokeServer" then
        local remoteName = tostring(self.Name):lower()
        if remoteName:find("report") or remoteName:find("ban") or remoteName:find("kick") or 
           remoteName:find("punish") or remoteName:find("log") or remoteName:find("detect") then
            warn("[CYDEX] Remote bloqueado: " .. self.Name)
            return nil
        end
    end

    return oldNamecall(self, ...)
end))

setreadonly(mt, true)

-- Proteção contra error de exploit
local oldError = error
error = newcclosure(function(message, level)
    if tostring(message):lower():find("exploit") or tostring(message):lower():find("hack") or 
       tostring(message):lower():find("cheat") then
        warn("[CYDEX] Error exploit bloqueado")
        return nil
    end
    return oldError(message, level)
end))

