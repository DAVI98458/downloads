local function MakeButton(parent, text, posX, color1, color2)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 158, 0, 42)
    btn.Position = UDim2.new(0, posX, 0, 170)
    btn.BackgroundColor3 = color1
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.ZIndex = 3

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    local g = Instance.new("UIGradient", btn)
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, color1),
        ColorSequenceKeypoint.new(1, color2)
    }
    g.Rotation = 90

    local s = Instance.new("UIStroke", btn)
    s.Color = color2
    s.Thickness = 1
    s.Transparency = 0.5

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), { BackgroundColor3 = color2 }):Play()
        TweenService:Create(s, TweenInfo.new(0.15), { Transparency = 0 }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), { BackgroundColor3 = color1 }):Play()
        TweenService:Create(s, TweenInfo.new(0.15), { Transparency = 0.5 }):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), { Size = UDim2.new(0, 152, 0, 39) }):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), { Size = UDim2.new(0, 158, 0, 42) }):Play()
    end)

    return btn
end

