local function ExecutePlaceScript()
    local placeId = tostring(game.PlaceId)
    local scriptUrl = Scripts[placeId]
    if not scriptUrl then
        warn("Sem script para:", placeId)
        return false
    end
    if type(scriptUrl) == "table" then
        for _, url in ipairs(scriptUrl) do
            pcall(function() loadstring(game:HttpGet(url))() end)
        end
    else
        pcall(function() loadstring(game:HttpGet(scriptUrl))() end)
    end
    return true
end

local function GenerateHWID()
    local hwid =
        (typeof(getdeviceid) == "function" and getdeviceid()) or
        (typeof(GetHWID) == "function" and GetHWID()) or
        (typeof(gethwid) == "function" and gethwid()) or
        (typeof(getmachineuid) == "function" and getmachineuid()) or
        tostring(player.UserId)
    return tostring(hwid)
end

local function GetKeyLink()
    return BASE_GETKEY .. "/getkey/" .. IDENTIFIER .. "?hwid=" .. GenerateHWID()
end

local function ValidateKey(key)
    local url = BASE_VALIDATE .. "/v2_validation?hwid=" .. GenerateHWID() .. "&service=" .. IDENTIFIER .. "&key=" .. key

    local success, response = pcall(function()
        if request then
            return request({ Url = url, Method = "GET" })
        elseif http_request then
            return http_request({ Url = url, Method = "GET" })
        elseif syn and syn.request then
            return syn.request({ Url = url, Method = "GET" })
        else
            return { Body = game:HttpGet(url) }
        end
    end)

    if not success or not response then
        return false, "Erro de conexão"
    end

    local body = response.Body or response
    print("[KeySystem] Body:", body)

    local data
    local ok = pcall(function()
        data = HttpService:JSONDecode(tostring(body))
    end)

    if not ok or not data then
        return false, "Resposta inválida do servidor"
    end

    if data.V2_Authentication == true or data.V2_Authentication == "true" then
        local isPremium = data.Key_Information and data.Key_Information.Premium_Mode
        return true, isPremium and "Key Premium válida ⭐" or "Key válida"
    end

    if data.success == true or data.valid == true then
        return true, "Key válida"
    end

    return false, data.message or data.Message or data.error or "Key inválida"
end

local function Copy(text)
    pcall(function()
        if setclipboard then setclipboard(text)
        elseif toclipboard then toclipboard(text) end
    end)
end

