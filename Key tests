local function GenerateHWID()
    local userId = tostring(player.UserId)
    local hwid = ""
    for i = 1, #userId do
        hwid = hwid .. string.format("%02x", string.byte(userId, i))
    end
    return hwid
end

local function GetKeyLink()
    local hwid = GenerateHWID()
    return BASE_URL .. "/getkey?hwid=" .. hwid .. "&service=" .. IDENTIFIER
end

local function ValidateKey(key)
    local hwid = GenerateHWID()
    local url = BASE_URL .. "/v2_validation?hwid=" .. hwid .. "&service=" .. IDENTIFIER .. "&key=" .. key
    local success, response = pcall(function()
        return HttpService:GetAsync(url)
    end)
    if not success then
        return false, "Erro de conexão"
    end
    local valid, result = pcall(function()
        return HttpService:JSONDecode(response)
    end)
    if not valid then
        return false, "Erro ao processar resposta"
    end
    return result.valid == true or result.success == true, result
end

local function CopyToClipboard(text)
    local success = pcall(function()
        if syn and syn.write_clipboard then
            syn.write_clipboard(text)
            return true
        elseif setclipboard then
            setclipboard(text)
            return true
        elseif clipboard and clipboard.set then
            clipboard.set(text)
            return true
        elseif toclipboard then
            toclipboard(text)
            return true
        else
            local gui = Instance.new("ScreenGui")
            local box = Instance.new("TextBox")
            gui.Parent = playerGui
            box.Parent = gui
            box.Text = text
            box:CaptureFocus()
            box:ReleaseFocus()
            gui:Destroy()
            return true
        end
    end)
    return success
end

local function ExecutePlaceScript()
    local placeId = tostring(game.PlaceId)
    local scriptUrl = Scripts[placeId]
    if not scriptUrl then
        warn("Nenhum script configurado para este Place ID: " .. placeId)
        return false
    end
    if type(scriptUrl) == "table" then
        for _, url in ipairs(scriptUrl) do
            pcall(function()
                loadstring(game:HttpGet(url))()
            end)
        end
    else
        pcall(function()
            loadstring(game:HttpGet(scriptUrl))()
        end)
    end
    return true
end

