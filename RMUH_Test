local function TeleportAndFirePrompt(position, promptPath, times, returnOriginal)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local original = hrp.CFrame

    hrp.CFrame = CFrame.new(position)
    task.wait(0.3)

    local prompt = promptPath:FindFirstChildOfClass("ProximityPrompt")
    if prompt then
        for i = 1, (times or 1) do
            fireproximityprompt(prompt)
            task.wait(0.2)
        end
    end

    if returnOriginal ~= false then
        task.wait(0.2)
        hrp.CFrame = original
    end
end

