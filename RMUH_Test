-- Auto Scare
do
    local busy=false
    local conn
    local ROOM_POS={
        LivingRoom=Vector3.new(-24,7,-53),
        BottomCorridor=Vector3.new(-24,7,-84),
        Entrance=Vector3.new(-7,7,-36),
        Ladder=Vector3.new(-1,7,-62),
        TopCorridor=Vector3.new(-8,23,-76),
        TopCorridor2=Vector3.new(-28,23,-41),
        Bathroom=Vector3.new(-29,23,-48),
        Bedroom=Vector3.new(-16,23,-75)
    }

    Night1Tab:Toggle({
        Title = "Auto Scare (Stable)",
        Default = false,
        Callback = function(state)
            AutoScare.Value = state
            if conn then conn:Disconnect() conn=nil end
            if not state then busy=false return end
            conn=Workspace.ChildAdded:Connect(function(child)
                if not AutoScare.Value or busy then return end
                if child.Name~="Mutant" then return end
                local larry=child
                local cfg=larry:FindFirstChild("Config")
                local wandering=cfg and cfg:FindFirstChild("Wandering")
                if not wandering or wandering.Value~=false then return end
                local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                busy=true
                local original=hrp.CFrame
                for _,window in ipairs(Workspace.Windows:GetChildren()) do
                    local room=window.RoomName.Value
                    local pos=ROOM_POS[room]
                    if not pos then continue end
                    if (larry.PrimaryPart.Position - window:GetPivot().Position).Magnitude>12 then continue end
                    local light
                    for _,l in ipairs(Workspace.Lights:GetChildren()) do
                        if l.Status.RoomName.Value==room then light=l break end
                    end
                    if not light then continue end
                    local cd=light.Switch.Detector:FindFirstChildOfClass("ClickDetector")
                    if not cd then continue end
                    hrp.CFrame=CFrame.new(pos)
                    task.wait(0.35)
                    for i=1,3 do fireclickdetector(cd) task.wait(0.45) end
                    break
                end
                task.wait(0.2)
                hrp.CFrame=original
                busy=false
            end)
        end
    })
end

